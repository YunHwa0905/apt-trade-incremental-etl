<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.apttrade.web.mapper.DetectionMapper">

	<resultMap id="NewHighLowResultMap" type="NewHighLowVO">
		<id column="id" property="id" />
		<result column="apt_trade_id" property="aptTradeId" />
		<result column="apt_nm" property="aptNm" />
		<result column="sgg_cd" property="sggCd" />
		<result column="sgg_nm" property="sggNm" />
		<result column="record_type" property="recordType" />
		<result column="price_per_pyeong" property="pricePerPyeong" />
		<result column="deal_date" property="dealDate" />
	</resultMap>

	<resultMap id="OutlierTradeResultMap" type="OutlierTradeVO">
		<id column="id" property="id" />
		<result column="apt_trade_id" property="aptTradeId" />
		<result column="sgg_cd" property="sggCd" />
		<result column="sgg_nm" property="sggNm" />
		<result column="apt_nm" property="aptNm" />
		<result column="deal_price_per_pyeong"
			property="dealPricePerPyeong" />
		<result column="region_avg_price_per_pyeong"
			property="regionAvgPricePerPyeong" />
		<result column="deviation_rate" property="deviationRate" />
		<result column="dealing_gbn" property="dealingGbn" />
		<result column="sler_gbn" property="slerGbn" />
		<result column="buyer_gbn" property="buyerGbn" />
		<result column="deal_date" property="dealDate" />
	</resultMap>

	<!-- 법정동코드 -> 구이름 매핑 (서울 25개구 고정값이라 CASE WHEN으로 처리) -->
	<sql id="sggNmCase">
		CASE ${sggColumn}
		WHEN '11110' THEN '종로구'
		WHEN '11140' THEN '중구'
		WHEN '11170' THEN '용산구'
		WHEN '11200' THEN '성동구'
		WHEN '11215' THEN '광진구'
		WHEN '11230' THEN '동대문구'
		WHEN '11260' THEN '중랑구'
		WHEN '11290' THEN '성북구'
		WHEN '11305' THEN '강북구'
		WHEN '11320' THEN '도봉구'
		WHEN '11350' THEN '노원구'
		WHEN '11380' THEN '은평구'
		WHEN '11410' THEN '서대문구'
		WHEN '11440' THEN '마포구'
		WHEN '11470' THEN '양천구'
		WHEN '11500' THEN '강서구'
		WHEN '11530' THEN '구로구'
		WHEN '11545' THEN '금천구'
		WHEN '11560' THEN '영등포구'
		WHEN '11590' THEN '동작구'
		WHEN '11620' THEN '관악구'
		WHEN '11650' THEN '서초구'
		WHEN '11680' THEN '강남구'
		WHEN '11710' THEN '송파구'
		WHEN '11740' THEN '강동구'
		ELSE ${sggColumn}
		END
	</sql>

	<sql id="highLowWhere">
		<where>
			<if test="sggCd != null and sggCd != ''">
				AND sgg_cd = #{sggCd}
			</if>
			<if test="recordType != null and recordType != ''">
				AND record_type = #{recordType}
			</if>
		</where>
	</sql>

	<select id="selectNewHighLowList"
		parameterType="DetectionSearchCondition"
		resultMap="NewHighLowResultMap">
		SELECT
		id, apt_trade_id, apt_nm, sgg_cd,
		<include refid="sggNmCase">
			<property name="sggColumn" value="sgg_cd" />
		</include>
		AS sgg_nm,
		record_type, price_per_pyeong, deal_date
		FROM new_high_low_history
		<include refid="highLowWhere" />
		ORDER BY deal_date DESC, id DESC
		LIMIT #{pageSize} OFFSET #{offset}
	</select>

	<select id="countNewHighLowList"
		parameterType="DetectionSearchCondition" resultType="int">
		SELECT COUNT(*)
		FROM new_high_low_history
		<include refid="highLowWhere" />
	</select>

	<sql id="outlierWhere">
		<where>
			<if test="sggCd != null and sggCd != ''">
				AND o.sgg_cd = #{sggCd}
			</if>
		</where>
	</sql>

	<!-- 이상거래는 거래유형/매도매수자구분 등 부가정보를 보여주기 위해 apt_trade와 조인 -->
	<select id="selectOutlierList"
		parameterType="DetectionSearchCondition"
		resultMap="OutlierTradeResultMap">
		SELECT
		o.id, o.apt_trade_id, o.sgg_cd,
		<include refid="sggNmCase">
			<property name="sggColumn" value="o.sgg_cd" />
		</include>
		AS sgg_nm,
		o.apt_nm,
		o.deal_price_per_pyeong, o.region_avg_price_per_pyeong, o.deviation_rate,
		t.dealing_gbn, t.sler_gbn, t.buyer_gbn, t.deal_date
		FROM outlier_trade o
		JOIN apt_trade t ON o.apt_trade_id = t.id
		<include refid="outlierWhere" />
		<choose>
			<when test="sortBy == 'dealDate'">
				ORDER BY t.deal_date DESC, o.id DESC
			</when>
			<otherwise>
				ORDER BY ABS(o.deviation_rate) DESC
			</otherwise>
		</choose>
		LIMIT #{pageSize} OFFSET #{offset}
	</select>

	<select id="countOutlierList"
		parameterType="DetectionSearchCondition" resultType="int">
		SELECT COUNT(*)
		FROM outlier_trade o
		<include refid="outlierWhere" />
	</select>

</mapper>